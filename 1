function renderArt(){
  const a=WIKI[window._wikiKey]; if(!a)return renderWikiList();
  return `<div class="back-btn" onclick="go('wiki',{wikiKey:null})"><i class="ti ti-arrow-left"></i> Zurück</div>
  <div class="art">${a.html}</div>`;
