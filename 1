    <h3>💡 Merksätze</h3>
    <ul>
      <li><em>„Periodenanzahl = Schalenanzahl"</em></li>
      <li><em>„Gruppennummer (HG) = Valenzelektronen"</em></li>
      <li><em>„Edelgase (Gr. 18) haben volle Außenschale → unreaktiv"</em></li>
      <li><em>„Je weiter links und unten, desto reaktiver das Metall"</em></li>
      <li><em>„OIL RIG: Oxidation Is Loss, Reduction Is Gain"</em></li>
    </ul>
  </div>`;
}

/* ═══ SCHRITT 5: Strukturzeichner ═══ */
let _S={tool:'C',atoms:[],bonds:[],undoStack:[],sel:null,hover:null,drag:null,dragOfs:{x:0,y:0},grid:true,snap:true,isDown:false,mouse:{x:0,y:0}};

